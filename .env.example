# Copy this file to .env.local and fill in your values.

# MongoDB connection string. Local install or Atlas (mongodb+srv://...).
MONGODB_URI=mongodb://127.0.0.1:27017/indus-appliances

# Long random string used to sign session cookies.
JWT_SECRET=

# First admin account created by `npm run seed`.
SEED_ADMIN_NAME=Indus Admin
SEED_ADMIN_EMAIL=admin@indusappliances.com
SEED_ADMIN_PASSWORD=admin123
